digraph E0433Patcher_Teaching_Step2 {
  graph [
    rankdir=TB,
    fontsize=24,
    labelloc="t",
    label="Step 2 — Path Resolution (Vec<CandidateFix> -> ResolutionResult)",
    bgcolor="white",
    pad="0.25",
    nodesep="0.55",
    ranksep="0.75",
    splines="ortho"
  ];

  node [
    shape=box,
    style="rounded,filled",
    fillcolor="#F7F7F7",
    color="#444444",
    penwidth=1.6,
    fontname="Helvetica",
    fontsize=16
  ];

  edge [
    color="#444444",
    penwidth=1.3,
    fontname="Helvetica",
    fontsize=14,
    arrowsize=0.85
  ];

  in [label="Input: Vec<CandidateFix>\n(move / consumed)", fillcolor="#FFF4D6"];

  fn [label="PathResolver::resolve\n1) dedup/normalize\n2) apply decisions", fillcolor="#E9F5FF"];

  d1 [label="Any Confidence::High ?", shape=diamond, fillcolor="#FFFFFF"];
  d2 [label="Unique path count == 1 ?", shape=diamond, fillcolor="#FFFFFF"];
  h  [label="Heuristic\nprefer crate:: > std:: > short", fillcolor="#FFFFFF"];
  d3 [label="Still multiple after heuristic ?", shape=diamond, fillcolor="#FFFFFF"];

  r_ok1 [label="Resolved\nsource=CompilerMachineApplicable", fillcolor="#DFF7E3"];
  r_ok2 [label="Resolved\nsource=CompilerSuggestion", fillcolor="#DFF7E3"];
  r_ok3 [label="Resolved\nsource=Heuristic/StdLibMap", fillcolor="#DFF7E3"];
  r_amb [label="Ambiguous{candidates}", fillcolor="#FFE9E9"];
  r_un  [label="Unresolved{reason}", fillcolor="#FFE9E9"];

  out [label="Output: ResolutionResult\nResolved | Ambiguous | Unresolved", fillcolor="#E9F5FF"];

  in -> fn [label="move"];
  fn -> d1;

  d1 -> r_ok1 [label="yes"];
  d1 -> d2    [label="no"];

  d2 -> r_ok2 [label="yes"];
  d2 -> h     [label="no"];

  h  -> d3;
  d3 -> r_ok3 [label="no (picked one)"];
  d3 -> r_amb [label="yes"];

  fn -> r_un [style=dashed, label="if empty/invalid inputs"];

  r_ok1 -> out;
  r_ok2 -> out;
  r_ok3 -> out;
  r_amb -> out;
  r_un  -> out;
}
