digraph e0308_layers {
    rankdir=TB;
    fontname="Helvetica";
    node [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=11];
    edge [fontname="Helvetica", fontsize=10];

    label="E0308Patcher Analysis 流程：多源提取 + 五级分类 + Hints 生成";
    labelloc=t;
    fontsize=14;
    fontname="Helvetica-Bold";

    // Input
    diag [label="Diagnostic\n(E0308)", shape=ellipse, fillcolor="#FFF3E0"];

    // Layer 1: Multi-source type extraction
    subgraph cluster_l1 {
        label="第一层：多源类型提取（按优先级）";
        labeljust=l;
        style="rounded,filled";
        fillcolor="#E8F0FE4D";
        color="#1A73E8";
        fontname="Helvetica-Bold";
        fontsize=11;

        s1 [label="① Primary span label\n置信度: High", fillcolor="#BBDEFB"];
        s2 [label="② Child Note\n置信度: High", fillcolor="#BBDEFB"];
        s3 [label="③ Child Help /\nsuggested_replacement\n置信度: Medium", fillcolor="#90CAF9"];
        s4 [label="④ Main message\n（fallback）\n置信度: Low", fillcolor="#64B5F6"];

        re1 [label="RE_EXPECTED_FOUND_BACKTICK\n同时匹配 expected + found", fillcolor="#E8F0FE"];
        re2 [label="RE_EXPECTED_ONLY /\nRE_FOUND_ONLY", fillcolor="#E8F0FE"];
        efpair [label="ExpectedFoundPair\n+ confidence", fillcolor="#E8F0FE"];
    }

    // Layer 2: Five-level classification
    subgraph cluster_l2 {
        label="第二层：五级分类体系（按优先级命中即停止）";
        labeljust=l;
        style="rounded,filled";
        fillcolor="#FFF9C44D";
        color="#F57F17";
        fontname="Helvetica-Bold";
        fontsize=11;

        cls [label="分类判断\n（优先级降序）", shape=diamond, fillcolor="#FFF3E0"];

        c1 [label="① SetupHell\nfmt::Formatter / *mut / *const\nUnsafeCell / Pin\n【最高风险：框架内部类型】", fillcolor="#FFCDD2", style="rounded,filled"];
        c2 [label="② WrapperMismatch\n一侧含 Option/Result/Box/Rc/Arc\n另一侧不含\n【包装层不匹配】", fillcolor="#FFCDD2" ];
        c3 [label="③ MechanicalMismatch\n去引用后基础类型相同\n/ 字符串族 / 数值族\n【可机械变换】", fillcolor="#FFF9C4"];
        c4 [label="④ NominalHallucination\n含 :: 路径或大写名义类型\ntail 相同但路径不同\n【类型路径幻觉】", fillcolor="#FFF9C4"];
        c5 [label="⑤ Unknown\n以上不命中\n/ 提取失败", fillcolor="#E8F5E9"];
    }

    // Layer 3: Hints Generation
    subgraph cluster_l3 {
        label="第三层：Hints 生成";
        labeljust=l;
        style="rounded,filled";
        fillcolor="#E8F5E94D";
        color="#2E7D32";
        fontname="Helvetica-Bold";
        fontsize=11;

        h1 [label="SetupHell hints:\n避免构造运行时内部类型", fillcolor="#E8F5E9"];
        h2 [label="WrapperMismatch hints:\nSome(...) / Ok(...) / ?\n包装操作建议", fillcolor="#E8F5E9"];
        h3 [label="MechanicalMismatch hints:\n& / &mut / * / as\n.into() / .to_string()", fillcolor="#E8F5E9"];
        h4 [label="NominalHallucination hints:\n使用 crate 真实类型路径", fillcolor="#E8F5E9"];
        h_extra [label="前 3 条\nchildren_suggested_replacements\n（补充来源）", fillcolor="#E8F5E9"];
    }

    // Layer 4: Multi-diagnostic priority selection
    subgraph cluster_l4 {
        label="第四层：多诊断优先级选择（函数内多个 E0308 时）";
        labeljust=l;
        style="rounded,filled";
        fillcolor="#FCE4EC4D";
        color="#C62828";
        fontname="Helvetica-Bold";
        fontsize=11;

        priority [label="优先级排序\nSetupHell(5) > WrapperMismatch(4)\n> MechanicalMismatch(3)\n> NominalHallucination(2) > Unknown(1)\n同级按 confidence + hint 数量排序", fillcolor="#FCE4EC"];
        pick [label="选取最高优先级\n一条用于 Preflight 决策", fillcolor="#FCE4EC"];
    }

    // Preflight Decision
    subgraph cluster_pf {
        label="Preflight 决策映射";
        labeljust=l;
        style="rounded,filled";
        fillcolor="#F3E5F54D";
        color="#7B1FA2";
        fontname="Helvetica-Bold";
        fontsize=11;

        pd1 [label="SetupHell\n→ SkipLlmCommentOut", fillcolor="#FCE4EC"];
        pd2 [label="NominalHallucination + LowValue\n→ SkipLlmCommentOut", fillcolor="#FCE4EC"];
        pd3 [label="MechanicalMismatch / WrapperMismatch\n→ ContinueToLlmWithHints\n（注入类型对提示）", fillcolor="#FFF9C4"];
        pd4 [label="Unknown / 提取失败\n→ ContinueToLlm（保守放行）", fillcolor="#E8F5E9"];
    }

    // Output
    out [label="analyze() → 空 Vec\n(Analysis Patcher)\n+ Preflight Digest 注入:\nE0308_CLASSIFICATION\nE0308_EXPECTED / E0308_FOUND\nE0308_HINTS", shape=ellipse, fillcolor="#E8F0FE"];

    // Edges - extraction
    diag -> s1;
    diag -> s2;
    diag -> s3;
    diag -> s4;
    s1 -> re1;
    s2 -> re1;
    s3 -> re2;
    s4 -> re2;
    re1 -> efpair;
    re2 -> efpair;

    // Classification
    efpair -> cls;
    cls -> c1 [label="1st check"];
    cls -> c2 [label="2nd"];
    cls -> c3 [label="3rd"];
    cls -> c4 [label="4th"];
    cls -> c5 [label="fallback"];

    // Hints
    c1 -> h1;
    c2 -> h2;
    c3 -> h3;
    c4 -> h4;
    h1 -> priority;
    h2 -> priority;
    h3 -> priority;
    h4 -> priority;
    c5 -> priority;
    h_extra -> priority;

    // Multi-diag selection
    priority -> pick;

    // Preflight decision
    pick -> pd1;
    pick -> pd2;
    pick -> pd3;
    pick -> pd4;
    pd1 -> out;
    pd2 -> out;
    pd3 -> out;
    pd4 -> out;
}
